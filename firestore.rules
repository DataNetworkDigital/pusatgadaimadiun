rules_version = '2';

// Pusat Gadai Madiun
//
// Real collections (accounts/transactions/debts/reminders + config/settings)
// memerlukan Firebase Auth (anonymous sign-in di-handle otomatis oleh app).
//
// Demo collections (demo_*) terbuka untuk publik karena dipakai showcase
// portfolio. Data demo di-reset otomatis setiap hari oleh client (lazy
// reset) sehingga abuse hanya berdampak sampai reset berikutnya.
//
// Rules ini TIDAK pernah expire (no time-based check).

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ===== Real (auth-required) =====

    match /config/settings {
      allow read: if signedIn();
      allow create: if signedIn() && !exists(/databases/$(database)/documents/config/settings);
      allow update: if signedIn()
                    && request.resource.data.keys().hasOnly(['pinHash', 'createdAt', 'updatedAt'])
                    && request.resource.data.pinHash is string
                    && request.resource.data.pinHash.size() == 64;
      allow delete: if false;
    }

    match /accounts/{id}      { allow read, write: if signedIn(); }
    match /transactions/{id}  { allow read, write: if signedIn(); }
    match /debts/{id}         { allow read, write: if signedIn(); }
    match /reminders/{id}     { allow read, write: if signedIn(); }

    // ===== Demo (public) =====

    match /demo_config/{id}        { allow read, write: if true; }
    match /demo_accounts/{id}      { allow read, write: if true; }
    match /demo_transactions/{id}  { allow read, write: if true; }
    match /demo_debts/{id}         { allow read, write: if true; }
    match /demo_reminders/{id}     { allow read, write: if true; }

    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
