rules_version = '2';

// Pusat Gadai Madiun — single-tenant PIN-protected app dengan
// Firebase Anonymous Auth sebagai gerbang pertama. PIN tetap
// diverifikasi di client terhadap config/settings.pinHash.
//
// Rules ini TIDAK pernah expire (tidak pakai timestamp check) dan
// hanya mengizinkan request yang memiliki Auth token.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /config/settings {
      allow read: if signedIn();
      allow create: if signedIn() && !exists(/databases/$(database)/documents/config/settings);
      allow update: if signedIn()
                    && request.resource.data.keys().hasOnly(['pinHash', 'createdAt', 'updatedAt'])
                    && request.resource.data.pinHash is string
                    && request.resource.data.pinHash.size() == 64;
      allow delete: if false;
    }

    match /accounts/{id}      { allow read, write: if signedIn(); }
    match /transactions/{id}  { allow read, write: if signedIn(); }
    match /debts/{id}         { allow read, write: if signedIn(); }
    match /reminders/{id}     { allow read, write: if signedIn(); }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
